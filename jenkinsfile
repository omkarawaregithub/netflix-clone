
pipeline{
    agent any
    tools{
        jdk 'jdk21'
        nodejs 'node20'
    }
    environment {
        SCANNER_HOME=tool 'sonar-scanner'
    }
    stages {
        stage('clean workspace'){
            steps{
                cleanWs()
            }
        }
        stage('Checkout from Git'){
            steps{
                git branch: 'main', url: 'https://github.com/omkarawaregithub/netflix-clone.git'
            }
        }
        stage("Sonarqube Analysis "){
            steps{
                withSonarQubeEnv('sonar-server') {
                    sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=Netflix \
                    -Dsonar.projectKey=Netflix '''
                }
            }
        }
        stage('quality gate'){
            steps {
              script {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true, credentialsId: 'sonarqubq-token'
                }
              }
            }
        }
        stage('Install Dependencies') {
            steps {
                sh "npm install"
            }
        }
        stage('TRIVY FS SCAN') {
            steps {
                sh "trivy fs . > trivyfs.txt"
            }
        }
        stage("Docker Build & Push") {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'dockerhub-token') {
                        sh '''
                            docker build --no-cache -t netflix .
                            docker tag netflix omkaraware/netflix:latest
                            docker push omkaraware/netflix:latest
                        '''
                    }
                }
            }
        }
        stage("TRIVY"){
            steps{
                sh "trivy image omkaraware/netflix:latest > trivyimage.txt" 
            }
        }
        stage('Deploy to container'){
            steps{
                sh 'docker run -d --name netflix -p 8081:80 omkaraware/netflix:latest'
            }
        }
    }
}


If you get docker login failed error

sudo su
sudo usermod -aG docker jenkins
sudo systemctl restart jenkins

